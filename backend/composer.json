{
    "name": "jutform/backend",
    "description": "JutForm backend application",
    "type": "project",
    "autoload": {
        "psr-4": {
            "JutForm\\": "src/"
        },
        "files": [
            "src/Helpers/functions.php",
            "src/Helpers/security.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "JutForm\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-redis": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    }
}
